## ⚙️ 3. Installation & Database Schema Bootstrap
Follow this execution thread to build directories and lock down tables against external injection manipulation or raw phpMyAdmin bypass attempts.
## 3.1 Directory Topology Setup
Create this folder structure at your web server's public root node and adjust write permissions:

mkdir -p uploads/documents
chmod -R 755 uploads/documents

## 3.2 Relational Database Bootstrap Script
Execute this SQL statement within your phpMyAdmin query console tab to initialize tracking fields, general collations, and active trigger hooks [01-Jul-2026]:

CREATE DATABASE IF NOT EXISTS `college_admin` CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;
USE `college_admin`;
-- 1. Create Deletions Sync Tracker LogCREATE TABLE IF NOT EXISTS `deletions_log` (
  `id` INT AUTO_INCREMENT PRIMARY KEY,
  `target_table` VARCHAR(100) NOT NULL,
  `original_record_id` INT NOT NULL,
  `record_reference` VARCHAR(150) DEFAULT NULL,
  `deleted_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  `sync_status` ENUM('Pending','Synced','Failed') NOT NULL DEFAULT 'Pending',
  `last_synced_at` TIMESTAMP NULL DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;
-- 2. Create Cold Snapshot JSON Backup Vault ArchiveCREATE TABLE IF NOT EXISTS `deleted_records_archive` (
  `id` INT AUTO_INCREMENT PRIMARY KEY,
  `target_table` VARCHAR(100) NOT NULL,
  `original_record_id` INT NOT NULL,
  `record_reference` VARCHAR(150) NULL,
  `json_payload` LONGTEXT NOT NULL,
  `deleted_by` INT NOT NULL,
  `deleted_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;
-- 3. Set Delimiter to "//" at the bottom of phpMyAdmin before running the security triggers below:CREATE TRIGGER `trg_deletions_log_bypass_update_lock` BEFORE UPDATE ON `deletions_log` FOR EACH ROW BEGIN
    IF (@application_auth_context IS NULL OR @application_auth_context != 'SECURE_CAMPUS_DESK_TOKEN_2026') THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Security Violation: Cloud sync deletion queues are immutable.';
    END IF;END//
CREATE TRIGGER `trg_archive_bypass_delete_lock` BEFORE DELETE ON `deleted_records_archive` FOR EACH ROW BEGIN
    IF (@application_auth_context IS NULL OR @application_auth_context != 'SECURE_CAMPUS_DESK_TOKEN_2026') THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Security Violation: Cold storage archives cannot be dropped.';
    END IF;END//

