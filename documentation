## ⚙️ 4. Shared Backend Logic Core (helper_functions.php)
This module aggregates all reusable procedural algorithms, executing transactional row write-locks (FOR UPDATE), array conversions, and type-safe data generation algorithms.
## 4.1 Chronological Sequenced Reference Tracker Generator
Instead of assigning random byte parameters to data tokens, the system tracks the precise index category allocated in the current year, lock-screens concurrent updates, and appends a strict, sequential triple-digit identity block.

function generateInstitutionalTrackingNumber(PDO $con, int $indexCodeSelected): array {
    try {
        $indexDescriptionLabel = 'DOC';
        $masterIndexLookup = getInstitutionalFileIndexMap();
        
        foreach ($masterIndexLookup as $group => $items) {
            if (isset($items[$indexCodeSelected])) {
                $rawWords = explode(' ', str_replace(['/', '-', '.'], ' ', $items[$indexCodeSelected]));
                $indexDescriptionLabel = !empty($rawWords[0]) ? strtoupper($rawWords[0]) : 'DOC';
                break;
            }
        }

        $formattedPaddedIndex = str_pad((string)$indexCodeSelected, 2, '0', STR_PAD_LEFT);
        $currentYear = date('Y');
        $likePattern = "SDACOE-" . $indexDescriptionLabel . "-" . $formattedPaddedIndex . "-" . $currentYear . "-%";
        
        $query = "SELECT `document_number` FROM `documents` WHERE `document_number` LIKE :pattern ORDER BY `id` DESC LIMIT 1 FOR UPDATE";
        $stmt = $con->prepare($query);
        $stmt->execute([':pattern' => $likePattern]);
        $lastRecordedDocument = $stmt->fetch(PDO::FETCH_ASSOC);

        $nextSequenceNumber = 1;
        if ($lastRecordedDocument) {
            $codeSegmentsArray = explode('-', $lastRecordedDocument['document_number']);
            if (isset($codeSegmentsArray[4])) {
                $nextSequenceNumber = (int)$codeSegmentsArray[4] + 1;
            }
        }

        $formattedPaddedSequence = str_pad((string)$nextSequenceNumber, 3, '0', STR_PAD_LEFT);
        $compiledTrackingNumber = 'SDACOE-' . $indexDescriptionLabel . '-' . $formattedPaddedIndex . '-' . $currentYear . '-' . $formattedPaddedSequence;

        return ['status' => 'success', 'data' => $compiledTrackingNumber];
    } catch (\Throwable $e) {
        return ['status' => 'error', 'message' => $e->getMessage()];
    }
}

## 4.2 Universal Dynamic Hard Deletion Engine
Adhering strictly to DRY (Don't Repeat Yourself) criteria, this single abstraction logs the complete snapshot array row parameters, converts it into a compressed JSON packet, populates the cold archive table, and clears the file asset with zero parameter leaks.

function executeGlobalRecordHardDeletion(PDO $con, string $tableName, int $recordId, int $sessionUserId): array {
    try {
        $allowedSystemTables = ['documents', 'appointments', 'visitors_log', 'memos'];
        if (!in_array($tableName, $allowedSystemTables)) {
            throw new Exception("Security Violation: Action denied on table [{$tableName}].");
        }

        $cleanTableName = preg_replace('/[^a-zA-Z0-9_]/', '', $tableName);
        $lockStmt = $con->prepare("SELECT * FROM `$cleanTableName` WHERE `id` = :id LIMIT 1 FOR UPDATE");
        $lockStmt->execute([':id' => $recordId]);
        $targetRow = $lockStmt->fetch(PDO::FETCH_ASSOC);

        if (!$targetRow) throw new Exception("Record absent inside [{$cleanTableName}].");

        $recordReferenceString = "ID_REF_{$recordId}";
        $referencePriorityColumns = ['document_number', 'visitor_name', 'employee_id', 'memo_ref'];
        foreach ($referencePriorityColumns as $priorityCol) {
            if (isset($targetRow[$priorityCol]) && !empty(trim((string)$targetRow[$priorityCol]))) {
                $recordReferenceString = trim((string)$targetRow[$priorityCol]);
                break;
            }
        }

        $stringifiedJsonPayload = json_encode($targetRow, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
        $con->exec("SET @application_auth_context = 'SECURE_CAMPUS_DESK_TOKEN_2026'");

        $archiveQuery = "INSERT INTO `deleted_records_archive` (`target_table`, `original_record_id`, `record_reference`, `json_payload`, `deleted_by`) VALUES (:tbl, :orig_id, :rec_ref, :json_data, :user_id)";
        $con->prepare($archiveQuery)->execute([
            ':tbl' => $cleanTableName, ':orig_id' => $recordId, ':rec_ref' => $recordReferenceString, ':json_data' => $stringifiedJsonPayload, ':user_id' => $sessionUserId
        ]);

        $con->prepare("DELETE FROM `$cleanTableName` WHERE `id` = :id")->execute([':id' => $recordId]);
        recordSystemActivityLog($con, ucfirst($cleanTableName), 'HARD_DELETE', "[User: {$sessionUserId}] Deleted record ref: {$recordReferenceString}. Snapshot archived to JSON.");

        return ['status' => 'success', 'message' => "Record purged and snapshot archived cleanly."];
    } catch (\Throwable $e) {
        return ['status' => 'error', 'message' => $e->getMessage()];
    }
}

